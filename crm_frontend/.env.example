# API Base URL — backend (Render in production, localhost in dev)
# Local:  http://localhost:4000
# Render: https://postcard-crm.onrender.com  (no trailing slash; note the hyphen)
VITE_API_BASE_URL=http://localhost:4000

# Hotel brand name (replaces Postcard references in UI)
VITE_HOTEL_BRAND=Postcard Hotels and Resorts

# Optional: Login placeholder for admin email
# VITE_ADMIN_EMAIL_PLACEHOLDER=admin@yourhotel.com
