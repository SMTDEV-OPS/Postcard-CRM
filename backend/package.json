    "seed:leads:dummy": "ts-node scripts/seedDummyLeads.ts",
    "seed:property-kb:excel": "ts-node scripts/seedPropertyKnowledgeFromExcels.ts",
    "seed:everything": "ts-node scripts/seedEverything.ts",
    "seed:complete": "ts-node scripts/seedComplete.ts",
    "db:reset": "ts-node scripts/resetDatabase.ts",
    "db:clone:moustache-to-postcard": "bash scripts/cloneMoustacheToPostcard.sh",
    "list:users": "ts-node scripts/listUsers.ts",
    "test:v2-allocation": "ts-node scripts/testV2Allocation.ts",
    "reset:password": "ts-node scripts/resetPassword.ts",
    "lint": "echo \"no linter configured yet\"",
    "test": "ts-node"
