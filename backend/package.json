  "description": "PostcardCRM backend (Express + TypeScript + MongoDB/Mongoose)",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "postinstall": "npm run build",
    "seed:admin": "ts-node scripts/seedAdmin.ts",
    "seed:ezee-properties": "ts-node scripts/seedEzeeProperties.ts",
    "seed:newhotel": "ts-node scripts/seedNewHotel.ts",
    "seed:postcard-workflows": "ts-node scripts/seedPostcardWorkflows.ts",
