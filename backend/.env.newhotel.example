# New Hotel CRM - Separate from Postcard
# Copy this file to .env and configure for your new hotel

# IMPORTANT: Use a DIFFERENT database name to keep data fully separated from Postcard
# Postcard uses: mongodb://localhost:27017/postcardcrm
# Your new hotel should use its own database (e.g. newhotelcrm, yourhotelcrm, etc.)
MONGO_URI=mongodb://localhost:27017/newhotelcrm

PORT=4000
NODE_ENV=development
JWT_SECRET=change-me-in-production

# Optional: AWS for file uploads
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_S3_BUCKET_NAME=
