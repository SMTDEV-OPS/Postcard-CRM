# Copy to .env and fill in values.

# MongoDB — the database name is the path segment after the host (e.g. postcard_crm).
# On Atlas you do not "create" an empty database in the UI; it appears after the first write.
# Clone moustache_crm → postcard_crm locally (needs MongoDB Database Tools on PATH):
#   export SOURCE_MONGO_URI='.../moustache_crm?...'
#   export TARGET_MONGO_URI='.../postcard_crm?...'
#   npm run db:clone:moustache-to-postcard
# Wipe only postcard DB (then optionally npm run seed:complete):
#   CONFIRM_RESET_DB=YES npm run db:reset
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/postcard_crm?retryWrites=true&w=majority

JWT_SECRET=change-me-in-production
PORT=4000
NODE_ENV=development

# Netlify frontend URL (OAuth redirects, email links)
# FRONTEND_URL=https://<your-site>.netlify.app

# Postcard home-grown PMS CRM Customer API (Call Center lookup — server-side only)
# PMS_CRM_BASE_URL=https://staging.postcardresorts.com
# PMS_CRM_API_KEY=your-api-key
# PMS_CRM_SECRET_KEY=your-secret-key
